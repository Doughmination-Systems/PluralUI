# Copy to .env and fill in all values

JWT_SECRET=changeme_64char_random_string

# Discord OAuth2 App (discord.com/developers)
# Redirect URI: https://your-server.com/auth/discord/callback
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-server.com/auth/discord/callback

# GitHub OAuth App (github.com/settings/developers)
# Redirect URI: https://your-server.com/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://your-server.com/auth/github/callback

# Microsoft Azure App Registration (portal.azure.com)
# Redirect URI: https://your-server.com/auth/minecraft/callback
MICROSOFT_CLIENT_ID=your_azure_client_id
MICROSOFT_CLIENT_SECRET=your_azure_client_secret
MICROSOFT_REDIRECT_URI=https://your-server.com/auth/minecraft/callback

# HyAuth (hyauth.com)
HYAUTH_API_KEY=hta_key

# Public URL (no trailing slash)
PUBLIC_URL=https://plural.example.com

# DB service
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://plural:yourpassword@db:5432/plural